#!/usr/bin/env bash
# Block push if any song's audio: field still references a local path.
# Forces `npm run sync-audio` before deploying so production has all files.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

unsynced=()
for f in src/content/songs/*.md; do
  [ -f "$f" ] || continue
  audio=$(awk '/^audio:[[:space:]]/ {sub(/^audio:[[:space:]]*/, ""); sub(/[[:space:]]*$/, ""); print; exit}' "$f")
  [ -z "$audio" ] && continue
  case "$audio" in
    http://*|https://*) ;;
    *) unsynced+=("$f → $audio") ;;
  esac
done

if [ ${#unsynced[@]} -gt 0 ]; then
  echo "✗ Push blocked: audio not synced to R2 in:"
  for entry in "${unsynced[@]}"; do
    echo "    $entry"
  done
  echo ""
  echo "Run: npm run sync-audio"
  exit 1
fi
