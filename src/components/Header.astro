---
interface Props {
  artist?: string;
}

const { artist = 'Null Rail' } = Astro.props;
---

<nav class="site-nav">
  <div class="site-nav__inner">
    <a href="/" class="site-nav__brand">
      <span>{artist}</span>
    </a>
    <div class="site-nav__byline">
      by <a href="https://travisbriggs.com">Travis Briggs</a>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    background: #1f2937;
    border-bottom: 1px solid #111827;
    font-family: 'Roboto', sans-serif;
  }
  .site-nav__inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }
  .site-nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #fff;
    font-size: 22px;
    font-weight: 600;
  }
  .site-nav__byline {
    color: #9ca3af;
    font-size: 14px;
  }
  .site-nav__byline a {
    color: #3b82f6;
  }
</style>
